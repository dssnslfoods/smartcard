    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartcard.app",
      "infoPlist": {
        "NSCameraUsageDescription": "อนุญาตให้ SmartCard เข้าถึงกล้องเพื่อถ่ายรูปนามบัตร",
        "NSPhotoLibraryUsageDescription": "อนุญาตให้ SmartCard เข้าถึงรูปภาพเพื่อเลือกรูปนามบัตร"
      }
    },
    "android": {
      "package": "com.smartcard.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "อนุญาตให้ SmartCard เข้าถึงรูปภาพเพื่อเลือกรูปนามบัตร",

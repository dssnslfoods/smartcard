        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://smartcard--smartcard-d24ec.asia-southeast1.hosted.app",
      "eas": {
        "projectId": "13aa2c8f-f25a-4137-8b54-d6bddb02be78"
      }
    },
    "owner": "dssnslfoods",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/13aa2c8f-f25a-4137-8b54-d6bddb02be78"
    }

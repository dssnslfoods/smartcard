# Gemini API key — สร้างได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Service Account credentials (จาก Google Cloud Console → IAM → Service Accounts)
# คัดลอกจากไฟล์ JSON ที่ดาวน์โหลดมา
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ID ของ Google Sheet (อยู่ใน URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=

# ชื่อชีต/แท็บ ที่จะ append ข้อมูล (default: Sheet1)
GOOGLE_SHEET_TAB=Sheet1
